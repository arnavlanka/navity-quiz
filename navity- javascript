function showQuestion() {
  clearInterval(quizTimer);

  if (currentIndex >= currentQuestions.length) {
    coinAmount += 50;
    updateCoins();
    alert("Quiz finished! You earned bonus coins.");
    goHome();
    return;
  }

  const q = currentQuestions[currentIndex];
  question.innerText = q.q;
  answers.innerHTML = "";

  q.options.sort(() => Math.random() - 0.5).forEach(option => {
    const btn = document.createElement("button");
    btn.className = "answerBtn";
    btn.innerText = option;
    btn.onclick = () => checkAnswer(option);
    answers.appendChild(btn);
  });

  speak(q.q);
  startTimer();
}

function startTimer() {
  timeLeft = 20;
  timerText.innerText = timeLeft;
  loadingFill.style.width = "100%";

  quizTimer = setInterval(() => {
    timeLeft--;
    tickSound();

    timerText.innerText = timeLeft;
    loadingFill.style.width = (timeLeft * 5) + "%";

    if (timeLeft <= 0) {
      clearInterval(quizTimer);
      checkAnswer("TIME OUT");
    }
  }, 1000);
}

function checkAnswer(answer) {
  clearInterval(quizTimer);

  const q = currentQuestions[currentIndex];

  if (answer === q.correct) {
    coinAmount += 10;
    updateCoins();
    result.className = "correct";
    result.innerHTML = "Correct! ✨";
    speak("Correct!");
  } else {
    result.className = "wrong";
    result.innerHTML = `Incorrect ❌<br><br>Correct answer: ${q.correct}<br><br>Why: ${q.why}`;
    speak("Incorrect. The correct answer is " + q.correct + ". " + q.why);
  }

  setTimeout(() => {
    result.className = "hidden";
    currentIndex++;
    showQuestion();
  }, 3000);
}

function updateCoins() {
  coinText.innerText = coinAmount;
}

function showUpgrade() {
  hideAll();
  upgradePage.classList.remove("hidden");
  rankBox.innerHTML = "";

  ranks.forEach((rank, index) => {
    let need = index * 200;
    let div = document.createElement("div");
    div.className = "rankCard";

    if (coinAmount >= need) {
      div.classList.add("unlocked");
      div.innerText = `✅ ${rank} unlocked at ${need} coins`;
    } else {
      div.innerText = `🔒 ${rank} unlocks at ${need} coins`;
    }

    rankBox.appendChild(div);
  });
}

function goHome() {
  clearInterval(quizTimer);
  hideAll();
  home.classList.remove("hidden");
}

function stopGame() {
  clearInterval(quizTimer);
  bgMusic.pause();
  speechSynthesis.cancel();
  goHome();
}

function glitter(x, y) {
  for (let i = 0; i < 8; i++) {
    const spark = document.createElement("div");
    spark.className = "spark";
    spark.style.left = x + "px";
    spark.style.top = y + "px";
    spark.style.setProperty("--x", Math.random() * 80 - 40 + "px");
    spark.style.setProperty("--y", Math.random() * 80 - 40 + "px");
    document.body.appendChild(spark);
    setTimeout(() => spark.remove(), 700);
  }
}
