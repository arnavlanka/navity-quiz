  topicTitle.innerText = subject + " Topics";
  topicGrid.innerHTML = "";

  subjectData[subject].topics.forEach(topic => {
    const div = document.createElement("div");
    div.className = "topicCard";
    div.innerHTML = `${topic}<br><small>50 different questions</small>`;
