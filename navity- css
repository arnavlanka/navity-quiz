body {
  margin: 0;
  font-family: Arial;
  background: black;
  color: white;
  text-align: center;
}

header {
  background: linear-gradient(90deg, black, red, orange);
  padding: 18px;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

button {
  background: orange;
  color: black;
  padding: 14px 24px;
  border: 3px solid white;
  border-radius: 12px;
  font-size: 18px;
  font-weight: bold;
  cursor: pointer;
  margin: 8px;
}

button:hover {
  background: red;
  color: white;
}

#stopBtn {
  background: red;
  color: white;
}

.popup {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.95);
  z-index: 9999;
  display: flex;
  justify-content: center;
  align-items: center;
}

.popupBox {
  background: linear-gradient(135deg, orange, red, black);
  padding: 35px;
  border-radius: 25px;
  border: 5px solid orange;
  width: 70%;
}

.hidden {
  display: none !important;
}

#home {
  min-height: 85vh;
  display: flex;
  justify-content: space-around;
  align-items: center;
  flex-wrap: wrap;
  background: radial-gradient(circle, orange, darkred, black);
}

.card, .upgrade {
  background: #111;
  border: 4px solid orange;
  border-radius: 20px;
  padding: 25px;
  box-shadow: 0 0 25px red;
}

.card img {
  width: 220px;
  border-radius: 20px;
  border: 4px solid white;
  display: block;
  margin-bottom: 20px;
}

.bigPic {
  width: 170px;
  border-radius: 20px;
  border: 4px solid white;
}

.star {
  animation: float 1.4s infinite alternate;
}

@keyframes float {
  from { transform: translateY(0); }
  to { transform: translateY(-22px); }
}

.upgrade {
  font-size: 30px;
  cursor: pointer;
  background: linear-gradient(135deg, black, red, orange);
}

.page {
  min-height: 85vh;
  padding: 30px;
  background: linear-gradient(black, darkred, orange);
}

.grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
  gap: 20px;
  padding: 30px;
}

.subjectCard, .topicCard, .rankCard {
  background: #111;
  border: 4px solid orange;
  padding: 25px;
  border-radius: 20px;
  font-size: 22px;
  cursor: pointer;
  box-shadow: 0 0 18px red;
}

.subjectCard:hover, .topicCard:hover {
  background: orange;
  color: black;
}

.subjectPic {
  font-size: 55px;
  display: block;
  margin-bottom: 10px;
}

#timerText {
  font-size: 48px;
  color: orange;
  font-weight: bold;
}

.loadingBar {
  width: 80%;
  height: 28px;
  background: white;
  margin: 25px auto;
  border-radius: 20px;
  overflow: hidden;
}

#loadingFill {
  height: 100%;
  width: 100%;
  background: lime;
}

.answerBtn {
  display: block;
  margin: 15px auto;
  width: 70%;
  background: white;
  color: black;
}

#result {
  position: fixed;
  inset: 0;
  z-index: 8888;
  font-size: 40px;
  font-weight: bold;
  display: flex;
  justify-content: center;
  align-items: center;
  flex-direction: column;
}

.correct { background: green; }
.wrong { background: red; }

.spark {
  position: fixed;
  width: 6px;
  height: 6px;
  background: gold;
  border-radius: 50%;
  pointer-events: none;
  z-index: 10000;
  animation: sparkle 0.7s forwards;
}

@keyframes sparkle {
  to {
    transform: translate(var(--x), var(--y));
    opacity: 0;
  }
}

.rankCard {
  margin: 15px auto;
  max-width: 520px;
}

.unlocked {
  background: gold;
  color: black;
}
